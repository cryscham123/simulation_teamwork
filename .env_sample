# 환경변수 설정. 이 파일의 이름을 .env로 수정해서 사용하시오.
# 환경 변수에 원하는 값들을 입력해서 사용하시오.

# 공통 설정
BASE_DATA_PATH=
PM_ACTIVE=(True / False)
DOWN_ACTIVE=(True / False)
TIME_UNIT=(M/H/D)
DOWN_TIME_UNIT=(M/H/D)

# 룰베이스
PM_HAZARD_THRESHOLD=
MACHINE_RULE=(SPTSSU)
JOB_RULE=(random / FIFO / SPT / LPT / MIN_QTIME / SPTSSU)
PM_RULE=(THRESHOLD)

# GA
PM_LEVELS=                  # pm threshold 값 (값 개수 바꿔도 적용 가능)
POP_SIZE=                   # 한 세대 집단 수
N_GENERATIONS=              # 세대 수
CROSSOVER_RATE=             # 교차 확률 (0.0 ~ 1.0)
MUT_JOB=                    # job_seq 유전자 mutation 확률 (0.0 ~ 1.0)
MUT_MACHINE=                # machine 유전자 mutation 확률 (0.0 ~ 1.0)
MUT_PM=                     # pm 유전자 mutation 확률 (0.0 ~ 1.0)
TOURNAMENT_K=               # 토너먼트 선택 후보 수 (양의 정수)
N_ELITES=                   # 엘리트 보존 개수 (다음 세대로 그대로 복사)
ALPHA=                      # fitness = makespan + α·qtime_violation 의 가중치
SEED=                       # 난수 시드 (정수). 비워두면 매 실행마다 랜덤 생성
