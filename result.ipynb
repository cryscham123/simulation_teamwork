        "# 이벤트 로거 생성\n",
        "event_logger = EventLogger(env)\n",
        "\n",
        "# 스케줄러 생성\n",
        "scheduler = Scheduler(env=env,\n",
        "                      data=data,\n",
        "                      event_logger=event_logger,\n",
        "                      pm_hazard_threshold=float(PM_HAZARD_THRESHOLD),\n",
        "                      qtime_urgency_factor=float(QTIME_URGENCY_FACTOR))"
      ]
